# Default: auto-detect text files, normalize to LF in repo, check out as LF
# on every platform. Prevents the WSL/Windows CRLF churn we hit before.
* text=auto eol=lf

# Scripts that must keep their native line endings
*.sh    text eol=lf
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.exe   binary
*.dll   binary
*.node  binary
*.db    binary
*.db-wal binary
*.db-shm binary
*.sqlite binary
*.sqlite3 binary
*.zip   binary
*.tar   binary
*.gz    binary
*.pdf   binary
